border-bottom-left-radius:14px;
border-bottom-right-radius:14px;
	background-color: qlineargradient(
        spread:pad,
        x1:0, y1:0, x2:1, y2:0,   /* 水平向右渐变 */
        stop:0 rgba(0, 171, 149, 0.5),    /* 左边界开始颜色 */
        stop:0.3 rgba(255, 255, 255, 255),/* 30%位置变为白色 */
        stop:0.7 rgba(255, 255, 255, 255),/* 保持白色到70%位置 */
        stop:1 rgba(0, 171, 149, 0.5)     /* 右边界结束颜色 */
    );
}
